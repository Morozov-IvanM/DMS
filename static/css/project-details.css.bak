/* ==========================================================
   PROJECT DETAILS: DARK THEME (WHITE TEXT & BORDERS)
   ========================================================== */

/* 1. ГЛАВНАЯ КАРТОЧКА ПРОЕКТА */
.project-detail-card {
    background-color: #1a1d26 !important; /* Темно-серый */
    border: 2px solid #303645 !important; /* Четкая серая граница */
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    color: #ffffff !important;
}

.project-title {
    color: #ffffff !important;
    font-weight: 700;
    font-size: 2rem;
    margin-bottom: 1rem;
}

.project-description {
    background-color: #242834;
    border: 1px solid #303645;
    color: #e2e8f0; /* Почти белый для текста */
    padding: 1.25rem;
    border-radius: 12px;
    line-height: 1.6;
}

/* 2. КАРТОЧКИ КОММЕНТАРИЕВ */
.comment-card {
    background-color: #1a1d26 !important;
    border: 2px solid #303645 !important; /* Усиленная граница */
    border-radius: 14px;
    margin-bottom: 1.5rem;
    overflow: hidden;
    transition: border-color 0.2s;
}

.comment-card:hover {
    border-color: #3b82f6 !important; /* Синий акцент при наведении */
}

.comment-header {
    background-color: rgba(255, 255, 255, 0.03); 
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid #303645;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.comment-author {
    color: #3b82f6 !important; /* Ярко-синее имя */
    font-weight: 700;
}

.comment-time {
    color: #94a3b8 !important; /* Приглушенное время */
    font-size: 0.8rem;
}

.comment-body {
    padding: 1.25rem;
    color: #ffffff !important; /* БЕЛЫЕ БУКВЫ */
}

/* 3. ФОРМА ДОБАВЛЕНИЯ КОММЕНТАРИЯ */
.add-comment-card {
    background-color: #1a1d26 !important;
    border: 2px solid #303645 !important;
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.custom-textarea {
    width: 100%;
    background-color: #242834 !important;
    border: 1px solid #303645 !important;
    color: #ffffff !important;
    border-radius: 10px;
    padding: 1rem;
    min-height: 120px;
}

.custom-textarea:focus {
    border-color: #3b82f6 !important;
    outline: none;
}

/* 4. ВЛОЖЕНИЯ */
.attachments {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid #303645;
}

.file-link {
    background-color: #242834;
    border: 1px solid #303645;
    color: #3b82f6 !important;
    padding: 6px 14px;
    border-radius: 8px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.file-link:hover {
    background-color: #3b82f6;
    color: #ffffff !important;
}

/* ХЕДЕР ТЕМНЫЙ ФИКС */
.header {
    background: #1a1d26 !important;
    border-bottom: 1px solid #303645 !important;
}
/* Обертка формы как в чате */
.project-comment-input-area .chat-input-wrapper {
    display: flex;
    align-items: center;
    background: #242834 !important; /* Тёмный фон */
    border: 2px solid #303645;
    border-radius: 24px;
    padding: 6px 15px;
    transition: all 0.2s ease;
}

.project-comment-input-area .chat-input-wrapper:focus-within {
    border-color: #3b82f6;
    background: #1a1d26 !important;
}

.project-comment-input-area .chat-input-field {
    flex: 1;
    background: transparent;
    border: none;
    padding: 10px 15px;
    color: #ffffff;
    outline: none;
}

.project-comment-input-area .chat-attach-btn, 
.project-comment-input-area .chat-send-btn {
    color: #3b82f6;
    cursor: pointer;
    font-size: 1.1rem;
    border: none;
    background: transparent;
}
.file-link-modern {
    display: inline-flex;
    align-items: center;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.3);
    color: #3b82f6 !important;
    padding: 6px 12px;
    border-radius: 8px;
    text-decoration: none !important;
    font-size: 0.85rem;
    margin-right: 8px;
    margin-top: 8px;
    transition: all 0.2s ease;
}

.file-link-modern:hover {
    background: #3b82f6;
    color: #ffffff !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(59, 130, 246, 0.3);
}

.file-name-text {
    max-width: 200px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.btn-finish-project {
    position: relative;
    padding: 8px 20px;
    background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.btn-finish-project .btn-content {
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 2;
    position: relative;
}

/* Эффект блика при наведении */
.btn-finish-project .btn-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        120deg,
        transparent,
        rgba(255, 255, 255, 0.2),
        transparent
    );
    transition: all 0.6s;
}

/* Ховер-эффект */
.btn-finish-project:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
    background: linear-gradient(135deg, #f87171 0%, #dc2626 100%);
}

.btn-finish-project:hover .btn-shine {
    left: 100%;
}

/* Эффект нажатия */
.btn-finish-project:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(239, 68, 68, 0.3);
}

/* Иконка */
.btn-finish-project i {
    font-size: 0.9rem;
    transition: transform 0.3s;
}

.btn-finish-project:hover i {
    transform: scale(1.2);
}
.btn-restore-project {
    position: relative;
    padding: 8px 20px;
    /* Зеленый градиент (Emerald/Green) */
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.btn-restore-project .btn-content {
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 2;
    position: relative;
}

/* Эффект блика */
.btn-restore-project .btn-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        120deg,
        transparent,
        rgba(255, 255, 255, 0.2),
        transparent
    );
    transition: all 0.6s;
}

/* Ховер-эффект */
.btn-restore-project:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
    background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
}

.btn-restore-project:hover .btn-shine {
    left: 100%;
}

/* Эффект нажатия */
.btn-restore-project:active {
    transform: translateY(0);
    box-shadow: 0 2px 10px rgba(16, 185, 129, 0.3);
}

.btn-restore-project i {
    font-size: 0.9rem;
    transition: transform 0.3s;
}

.btn-restore-project:hover i {
    transform: rotate(-45deg) scale(1.2); /* Красивый поворот стрелки при наведении */
}
.comment-text {
    white-space: pre-wrap; /* Сохраняет пробелы и переносы строк */
    word-wrap: break-word; /* Переносит длинные слова */
}