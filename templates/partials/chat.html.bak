
<!-- ЛЕВАЯ КОЛОНКА: ЧАТ -->

<div class="card chat-card shadow-sm border-0">
	<div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
		<span>
			<i class="fas fa-comments me-2 text-info"></i> 
			{{ group_name if group_name else "Чат группы" }}
		</span>
		<span class="badge bg-success small" style="font-size: 0.6rem; letter-spacing: 1px;">
			<i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i> LIVE
		</span>
	</div>
	
	<div class="card-body chat-box" id="chat-window" style="height: 400px; overflow-y: auto; background: #f0f2f5; display: flex; flex-direction: column; gap: 12px; padding: 15px;">
		{% if chat_messages %}
			{% for msg in chat_messages|reverse %}
			<div class="chat-msg {% if msg[1] == user_name %}msg-me{% else %}msg-other{% endif %} shadow-sm" id="msg-container-{{ msg[0] }}">
				<div class="d-flex justify-content-between align-items-center mb-1">
					<span class="chat-author fw-bold" style="font-size: 0.85rem;">{{ msg[1] }}</span>
					
					<div class="chat-actions d-flex align-items-center gap-2">
						<!-- Кнопка редактирования (только для своих) -->
						{% if msg[1] == user_name %}
						<button type="button" class="btn-chat-edit border-0" 
								onclick="toggleChatEdit('{{ msg[0] }}')" title="Редактировать">
							<i class="fas fa-pen"></i>
						</button>
						{% endif %}

						<!-- Кнопка удаления (админ) -->
						{% if user_name == "Администратор" %}
						<button type="button" class="chat-admin-delete border-0 bg-transparent p-0" 
								onclick="confirmDeleteMessage({{ msg[0] }}, this)" title="УДАЛИТЬ">
							<i class="fas fa-trash-alt" style="font-size: 0.8rem; color: #dc3545; opacity: 0.6;"></i>
						</button>
						{% endif %}
					</div>
				</div>
				
				<!-- Контент сообщения -->
				<div class="chat-text" id="chat-text-{{ msg[0] }}">{{ msg[2] }}</div>

				<!-- УЛУЧШЕННАЯ ФОРМА РЕДАКТИРОВАНИЯ -->
				{% if msg[1] == user_name %}
				<div id="chat-edit-block-{{ msg[0] }}" style="display: none;" class="animate-edit">
					<div class="chat-edit-container">
						<textarea class="form-control" id="edit-input-{{ msg[0] }}" rows="3">{{ msg[2] }}</textarea>
						<div class="d-flex justify-content-end align-items-center gap-1">
							<button class="edit-btn-cancel" onclick="toggleChatEdit('{{ msg[0] }}')">Отмена</button>
							<button class="edit-btn-save shadow-sm" onclick="saveChatEdit('{{ msg[0] }}')">Сохранить</button>
						</div>
					</div>
				</div>
				{% endif %}
				
				{% if msg[4] %}
				<div class="chat-file-attachment mt-2 pt-1 border-top border-light-subtle">
					<a href="/download_chat/{{ msg[4] }}" target="_blank" class="text-decoration-none small">
						<i class="fas fa-paperclip me-1"></i> {{ msg[5] }}
					</a>
				</div>
				{% endif %}
				<span class="chat-time text-muted d-block mt-1 text-end" style="font-size: 0.65rem;">{{ msg[3] }}</span>
			</div>
			{% endfor %}
		{% else %}
			<div id="chat-empty" class="text-center my-auto px-4">
				<div class="mb-3"><i class="fas fa-ghost text-muted" style="font-size: 3rem; opacity: 0.2;"></i></div>
				<h6 class="text-muted fw-bold">Здесь пока тихо...</h6>
			</div>
		{% endif %}
	</div>

	<!-- ФОРМА ОТПРАВКИ -->
	<div class="card-footer bg-white border-top-0 py-3 mt-3 shadow-sm" style="border-radius: 0 0 20px 20px;">
		<form id="chat-form-js" enctype="multipart/form-data">
			<div class="chat-input-wrapper">
				<label class="chat-attach-btn" for="chat-file">
					<i class="fas fa-paperclip"></i>
					<input type="file" id="chat-file" style="display:none">
				</label>
				<input type="text" id="chat-input-js" class="chat-input-field" placeholder="Сообщение..." autocomplete="off">
				<button class="chat-send-btn" type="submit">
					<i class="fas fa-paper-plane"></i>
				</button>
			</div>
			<div id="file-preview-container" class="file-preview-bar shadow-sm" style="display:none;">
				<div class="d-flex align-items-center justify-content-between w-100">
					<span id="file-preview-name" class="small text-truncate me-2"></span>
					<i class="fas fa-times-circle" id="remove-file-btn" style="cursor:pointer; opacity: 0.8;"></i>
				</div>
			</div>
		</form>
	</div>
</div>


<script>
function toggleChatEdit(msgId) {
    const textDiv = document.getElementById(`chat-text-${msgId}`);
    const editBlock = document.getElementById(`chat-edit-block-${msgId}`);
    
    if (editBlock.style.display === 'none') {
        editBlock.style.display = 'block';
        textDiv.style.display = 'none';
        const input = document.getElementById(`edit-input-${msgId}`);
        input.focus();
        input.selectionStart = input.selectionEnd = input.value.length;
    } else {
        editBlock.style.display = 'none';
        textDiv.style.display = 'block';
    }
}

async function saveChatEdit(msgId) {
    const textarea = document.getElementById(`edit-input-${msgId}`);
    const saveBtn = event.target; // Кнопка, на которую нажали
    const newText = textarea.value;
    
    if (!newText.trim()) return;

    saveBtn.disabled = true;
    saveBtn.innerText = "...";

    try {
        const response = await fetch(`/chat/message/${msgId}/edit`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ 'text': newText })
        });

        if (response.ok) {
            document.getElementById(`chat-text-${msgId}`).innerText = newText;
            toggleChatEdit(msgId);
        } else {
            alert("Ошибка сохранения");
        }
    } catch (e) {
        console.error("Ошибка:", e);
    } finally {
        saveBtn.disabled = false;
        saveBtn.innerText = "Сохранить";
    }
}
</script>