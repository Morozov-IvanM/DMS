<!DOCTYPE html>
<!-- Project.html -->
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ project[1] if project else 'Проект' }} | CMR</title>
    
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='fontawesome/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/components.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/project-details.css') }}">
</head>
<body>
    <header class="header">
        <div class="header-content">
            <a href="/" class="logo-link text-decoration-none">
                <div class="logo">
                    <i class="fas fa-code-branch"></i> CMR Safe Region 34
                </div>
            </a>
            <div class="header-actions">
                <a href="/" class="btn btn-outline-light btn-sm me-2">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
                {% if project and project[3] == 'Active' %}
                <form action="/archive-project/{{ project[0] }}/" method="post" style="display:inline;">
					<button type="submit" class="btn btn-outline-warning btn-sm" title="В архив">
						<i class="fas fa-archive"></i>
					</button>
				</form>
                {% elif project and project[3] == 'Archived' %}
                <form action="/project/{{ project[0] }}/restore" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-outline-success btn-sm">
                        <i class="fas fa-undo-alt"></i> Восстановить
                    </button>
                </form>
                {% endif %}
            </div>
        </div>
    </header>

    <main class="page-container">
        {% if project %}
            <!-- Карточка проекта -->
            <div class="project-detail-card shadow-sm">
                <div class="project-header">
                    <div class="project-icon"><i class="fas fa-folder-open"></i></div>
                    <div class="project-info">
                        <h1 class="project-title">{{ project[1] }}</h1>
                        <div class="project-meta">
                            <span class="badge {% if project[3] == 'Active' %}bg-success{% else %}bg-secondary{% endif %}">
                                {{ 'Активен' if project[3] == 'Active' else 'В архиве' }}
                            </span>
                            <span class="project-id ms-2 text-muted">ID: {{ project[0] }}</span>
                        </div>
                    </div>
                </div>
                <div class="project-description mt-3">
                    <p class="mb-0">{{ project[2] if project[2] else 'Описание отсутствует' }}</p>
                </div>
            </div>

			<!-- ФОРМА ДОБАВЛЕНИЯ -->
            {% if project[3] == 'Active' %}
            <div class="add-comment-card shadow-sm mb-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-plus-circle me-2"></i>Добавить запись</h5>
                <form action="/project/{{ project[0] }}/comment" method="post" enctype="multipart/form-data">
                    <textarea name="text" class="form-control mb-3" placeholder="Ваше сообщение..." required rows="3"></textarea>
                    <div class="d-flex justify-content-between align-items-center">
                        <input type="file" name="file" class="form-control form-control-sm w-50">
                        <button type="submit" class="btn btn-primary btn-sm px-4">Отправить</button>
                    </div>
                </form>
            </div>
            {% endif %}
				
            <!-- Секция комментариев -->
            <div class="comments-section-wrapper">
                <h5 class="fw-bold mb-3">Обсуждение ({{ comments|length }})</h5>
                <div class="comments-feed">
                    {% for c in comments %}
                    <div class="comment-card shadow-sm mb-3">
                        <div class="comment-header d-flex justify-content-between">
                            <div>
                                <i class="fas fa-user-circle me-1"></i>
                                <span class="comment-author">{{ c[1] }}</span>
                            </div>
                            <small class="text-muted">{{ c[3].strftime('%d.%m.%Y %H:%M') if c[3] else '' }}</small>
                        </div>
                        <div class="comment-body p-3">
                            <p class="mb-0">{{ c[2] }}</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </main>

    {% include 'partials/footer.html' %}

    <script src="{{ url_for('static', path='js/bootstrap.bundle.min.js') }}"></script>
</body>
</html>