<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DMS — Список проектов</title>
    <link href="/static/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .project-link { text-decoration: none; color: inherit; }
        .project-card {
            background: white;
            border-radius: 12px;
            border: 1px solid #e0e0e0;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .project-card:hover {
            transform: translateY(-3px);
            border-color: #0d6efd;
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
        }
        .empty-state { text-align: center; padding: 40px; color: #6c757d; }
        /* Увеличим до 1200px, чтобы две колонки влезли красиво */
        .container { max-width: 400px; }
        .transition-all { transition: all 0.2s ease-in-out; }
        .hover-shadow:hover {  transform: translateX(5px); box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important; }
        .border-4 { border-width: 4px !important; }
    </style>
</head>
<body class="container py-5">

    <!-- 1. ШАПКА (Название, Архив, Поиск, Пользователь) -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">📂 DMS Система</h2>
        <div class="d-flex align-items-center gap-3">
            <a href="/archive" class="btn btn-outline-secondary btn-sm">📁 Архив</a>
            <form action="/" method="get" class="d-flex">
                <div class="input-group input-group-sm">
                    <input type="text" name="q" class="form-control" placeholder="Поиск..." value="{{ search_query or '' }}" style="width: 150px;">
                    <button class="btn btn-primary" type="submit">🔍</button>
                </div>
            </form>
            <div class="text-muted border-start ps-3 small">
                <strong>{{ user_name }}</strong>
                <a href="/logout" class="ms-2 text-danger text-decoration-none">Выйти</a>
            </div>
        </div>
    </div>

    <!-- 2. ФОРМА СОЗДАНИЯ ПРОЕКТА -->
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-body p-4">
            <h5 class="card-title mb-3 text-primary">Новый проект</h5>
            <form action="/create_project" method="post" class="row g-3">
                <div class="col-md-4"><input type="text" name="name" class="form-control" placeholder="Название" required></div>
                <div class="col-md-6"><input type="text" name="description" class="form-control" placeholder="Описание"></div>
                <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Создать</button></div>
            </form>
        </div>
    </div>

    <!-- 3. ОСНОВНОЙ КОНТЕНТ (ДВЕ КОЛОНКИ) -->
    <div class="row">
        <!-- Левая часть: Список проектов -->
        <div class="col-lg-8">
            <h4 class="mb-4">Активные проекты</h4>
            <div class="row row-cols-1 row-cols-md-2 g-4">
                {% if projects %}
                    {% for p in projects %}
                    <div class="col">
                        <a href="/project/{{ p[0] }}" class="project-link h-100">
                            <div class="project-card p-3 shadow-sm h-100 d-flex flex-column">
                                <h5 class="h6 fw-bold text-dark mb-1">{{ p[1] }}</h5>
                                <p class="text-secondary mb-0 small flex-grow-1">
                                    {{ p[2][:60] + '...' if p[2] and p[2]|length > 60 else p[2] or 'Нет описания' }}
                                </p>
                            </div>
                        </a>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="col-12"><p class="text-muted">Проекты не найдены</p></div>
                {% endif %}
            </div>
        </div>

        <!-- Правая часть: 5 последних комментариев -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-transparent">
                <h5 class="card-title mb-4 fw-bold text-dark px-2">5 последних комментариев</h5>

                <div class="d-flex flex-column gap-3">
                    {% if last_comments %}
                        {% for c in last_comments %}
                        <a href="/project/{{ c[3] }}" class="project-link">
                            <div class="bg-white p-3 rounded-3 shadow-sm border-start border-primary border-4 hover-shadow transition-all">
                                <!-- Шапка комментария: Проект и Автор -->
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary border-0 text-truncate" style="max-width: 140px;">
                                        {{ c[2] }}
                                    </span>
                                    <small class="text-muted fw-bold">{{ c[1] }}</small>
                                </div>

                                <!-- Текст комментария -->
                                <div class="small text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">
                                    {{ c[0] }}
                                </div>
                            </div>
                        </a>
                        {% endfor %}
                    {% else %}
                        <div class="text-center py-4 bg-white rounded-3 shadow-sm text-muted small">
                            Комментариев пока нет
                        </div>
                    {% endif %}
                </div>
            </div>
</div>
    </div>

    <footer class="mt-5 pt-4 text-center text-muted border-top">
        <small>&copy; 2024 Морозов&Бабенко. Все права защищены.</small>
    </footer>
</body>
</html>