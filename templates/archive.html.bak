<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMR — Архив проектов</title>
    <!-- Используем те же стили, что и везде -->
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/corporate_reddit.css') }}">
</head>
<body>
    <!-- 1. Тот же хедер, что и на главной (он сам подставит поиск и юзера) -->
    <header class="header">
        {% include 'partials/header.html' %}
    </header>

    <div class="page-container">
        <!-- 2. Герой-секция (уникальна для архива, её оставляем тут) -->
        <div class="archive-hero">
            <div class="archive-hero-icon"><i class="fas fa-archive"></i></div>
            <div class="archive-hero-content">
                <h1>Архив проектов</h1>
                <p>Завершённые проекты и их резолюции. Здесь хранится история нашей работы.</p>
            </div>
            <div class="archive-stats">
                <div class="stat-item">
                    <span class="stat-value">{{ projects|length }}</span>
                    <span class="stat-label">проектов</span>
                </div>
            </div>
        </div>

        <!-- 3. Список архивных проектов -->
        <div class="archive-grid mt-4">
            {% if projects %}
                <div class="projects-grid">
                    {% for p in projects %}
                        <!-- Переиспользуем твой стиль карточек, но можем добавить класс archive-mode -->
                        <a href="/project/{{ p[0] }}" class="project-link archive-mode">
                            <div class="project-grid-card shadow-sm">
                                <div class="project-card-header">
                                    <span class="project-id-badge">#{{ p[0] }}</span>
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-check-circle"></i> Завершён
                                    </span>
                                </div>
                                <h4 class="project-card-title">{{ p[1] }}</h4>
                                <p class="project-card-description">
                                    {{ p[2][:120] if p[2] else 'Описание отсутствует' }}
                                </p>
                                <div class="project-card-footer text-muted small">
                                    <i class="fas fa-calendar-alt"></i> {{ p[3] if p[3] else 'Нет даты' }}
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state-card text-center p-5">
                    <i class="fas fa-archive fa-3x mb-3 text-muted"></i>
                    <h3>Архив пуст</h3>
                    <p>Здесь будут отображаться завершенные проекты.</p>
                </div>
            {% endif %}
        </div>

        <!-- 4. Общий футер и модалки -->
        {% include 'partials/footer.html' %}
    </div>

    <!-- 5. Общие скрипты -->
    {% include 'partials/scripts.html' %}
</body>
</html>