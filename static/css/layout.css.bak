/* Убираем хедер на странице логина (если он случайно появится) */
body.login-page .header {
    display: none;
}
/* Хедер - на всю ширину, прижат к верху */
.header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    z-index: 1000;
    backdrop-filter: blur(10px);
    background: rgba(22, 24, 28, 0.95);
}

/* Контент хедера - центрирован */
.header-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
}
/* Контейнер для правых элементов */
.header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
}

/* Адаптив для мобильных */
@media (max-width: 768px) {
    .header-content {
        flex-direction: column;
        padding: 0 1rem;
    }
    
    .header-actions {
        flex-direction: column;
        width: 100%;
    }
    
    .search-wrapper {
        width: 100%;
    }
    
    .search-input {
        width: 100%;
    }
    
    .user-info {
        width: 100%;
        justify-content: center;
    }
    
    .logo {
        white-space: normal;
        text-align: center;
    }
    
    .page-container {
        margin-top: 180px;
        padding: 0 1rem 1rem 1rem;
    }
}

/* Контейнер для правых элементов */
.header-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
}

/* Кнопка архива */
.btn-archive-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent-bg);
    color: var(--accent);
    padding: 0.5rem 1rem;
    border-radius: 40px;
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s;
}

.btn-archive-link:hover {
    background: var(--accent);
    color: #0a0c10;
}

/* Форма поиска */
.search-form {
    margin: 0;
}

.search-wrapper {
    display: flex;
    align-items: center;
    background: var(--bg-input);
    border-radius: 40px;
    padding: 0.25rem;
    border: 1px solid var(--border);
    transition: all 0.2s;
}
/* Карточка поста (проекта) */
.post-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.25rem;
    margin-bottom: 1rem;
    transition: all 0.2s;
}

.post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
}

.post-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
}

.post-author {
    font-weight: 600;
    color: var(--accent);
}

.post-time {
    font-size: 0.75rem;
    color: var(--text-secondary);
}

.post-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.4;
}

.post-content {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.6;
}
/* Футер */
.footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
}

.footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    font-size: 0.75rem;
    flex-wrap: wrap;
}

/* Адаптив для формы */
@media (max-width: 768px) {
    .form-row {
        flex-direction: column;
        align-items: stretch;
    }
    
    .form-group label {
        margin-top: 0.5rem;
    }
    
    .form-group:first-child label {
        margin-top: 0;
    }
    
    .flex-1, .flex-2, .flex-3 {
        min-width: auto;
    }
    
    .btn-primary {
        margin-top: 0.5rem;
    }
}
