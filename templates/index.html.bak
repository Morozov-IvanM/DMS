<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMR — Лента проектов</title>
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
	<link rel="stylesheet" href="{{ url_for('static', path='css/corporate_reddit.css') }}">
	<link rel="stylesheet" href="{{ url_for('static', path='css/chat.css') }}"> <!-- Самый приоритетный -->
</head>
<body>		
	<!-- Хедер --> 
	<header class="header">
    {% include 'partials/header.html' %}    
    </header>
																
	{% include 'partials/chat.html' %}
		
    <div class="page-container">
        <!-- Форма создания проекта -->
		{% include 'partials/create_project_form.html' %}
        <!-- Основной контент: две колонки -->
        <div class="two-columns">
			<div class="left-column">
            <!-- Левая колонка: список проектов -->
            {% include 'partials/projects_list.html' %}
			</div>
            <!-- Правая колонка: последние комментарии -->
            <div class="right-column">
			{% include 'partials/recent_comments.html' %}
			</div>
        </div>

        <!-- Футер -->
    {% include 'partials/footer.html' %}
    </div>
	
 <!-- 5. Общие скрипты -->
    {% include 'partials/scripts.html' %}
</body>
</html>