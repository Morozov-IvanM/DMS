<!-- Глобальный чат -->
<div class="card chat-card shadow-sm mb-4 border-0">
    <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
        <span>
            <i class="fas fa-comments me-2 text-info"></i> 
            {{ group_name if group_name else "Чат группы" }}
        </span>
        <span class="badge bg-success small" style="font-size: 0.6rem; letter-spacing: 1px;">
            <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i> LIVE
        </span>
    </div>
    
    <div class="card-body chat-box" id="chat-window" style="height: 350px; overflow-y: auto; background: #f0f2f5; display: flex; flex-direction: column; gap: 10px; padding: 15px;">
        {% if chat_messages %}
            {% for msg in chat_messages|reverse %}
            <div class="chat-msg {% if msg[1] == user_name %}msg-me{% else %}msg-other{% endif %} shadow-sm">
                <span class="chat-author">{{ msg[1] }}</span>
                
                {% if user_name == "Администратор" %}
                <button type="button" class="chat-admin-delete" 
                        onclick="confirmDeleteMessage({{ msg[0] }}, this)"
                        title="УДАЛИТЬ">
                    <i class="fas fa-trash-alt"></i>
                </button>
                {% endif %}
                
                <div class="chat-text">{{ msg[2] }}</div>
                
                {% if msg[4] %}
                <div class="chat-file-attachment mt-2 pt-1 border-top border-light-subtle">
                    <a href="/download_chat/{{ msg[4] }}" target="_blank" class="text-decoration-none small">
                        <i class="fas fa-paperclip"></i> {{ msg[5] }}
                    </a>
                </div>
                {% endif %}
                <span class="chat-time text-muted">{{ msg[3] }}</span>
            </div>
            {% endfor %}
        {% else %}
            <div id="chat-empty" class="text-center my-auto px-4">
                <div class="mb-3"><i class="fas fa-ghost text-muted" style="font-size: 3rem; opacity: 0.2;"></i></div>
                <h6 class="text-muted fw-bold">Здесь пока тихо...</h6>
                <p class="small text-secondary">Напишите первое сообщение группе!</p>
            </div>
        {% endif %}
    </div>

    <!-- ОБНОВЛЕННАЯ ФОРМА ОТПРАВКИ -->
    <div class="card-footer bg-white border-top-0 py-3">
        <form id="chat-form-js" enctype="multipart/form-data">
            <div class="chat-input-wrapper">
                <!-- Скрепка -->
                <label class="chat-attach-btn" for="chat-file" title="Приложить документ">
                    <i class="fas fa-paperclip"></i>
                    <input type="file" id="chat-file" style="display:none">
                </label>

                <!-- Поле ввода -->
                <input type="text" id="chat-input-js" 
                       class="chat-input-field" 
                       placeholder="Напишите сообщение..." 
                       autocomplete="off">

                <!-- Кнопка отправить -->
                <button class="chat-send-btn" type="submit" id="chat-send-btn">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
            
            <!-- Улучшенный предпросмотр файла -->
            <div id="file-preview-container" class="file-preview-bar shadow-sm" style="display:none;">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <span id="file-preview-name" class="small text-truncate me-2"></span>
                    <i class="fas fa-times-circle" id="remove-file-btn" style="cursor:pointer; opacity: 0.8;"></i>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Контейнер для выпадающего списка подсказок -->
<div id="mention-list" class="list-group shadow" style="display:none; position:absolute; z-index:1000; max-height:200px; overflow-y:auto;"></div>
