/* ГАРАНТИРУЕМ, ЧТО КОНТЕЙНЕР СООБЩЕНИЯ ПРАВИЛЬНЫЙ */
.chat-msg {
    position: relative !important; /* База для кнопки */
    overflow: visible !important; /* Чтобы кнопка не обрезалась краями */
    min-height: 50px !important;   /* Защита от схлопывания */
    display: block !important;     /* Или flex, главное не inline */
}

/* САМА КНОПКА - МАКСИМАЛЬНЫЙ ПРИОРИТЕТ */
button.chat-admin-delete {
    /* 1. Позиционирование (внутри облачка, в углу) */
    position: absolute !important;
    top: 5px !important;
    right: 5px !important;
    
    /* 2. Отображение (форсируем видимость) */
    display: flex !important;
    visibility: visible !important;
    opacity: 1 !important;
    
    /* 3. Геометрия */
    width: 24px !important;
    height: 24px !important;
    padding: 0 !important;
    margin: 0 !important;
    border-radius: 50% !important;
    
    /* 4. Цвета (Красный фон, белый крест - не промахнешься) */
    background-color: #ef4444 !important; 
    color: #ffffff !important;
    border: 2px solid #ffffff !important; /* Белый ободок выделит на любом фоне */
    
    /* 5. Слой (самый верхний) */
    z-index: 9999 !important;
    cursor: pointer !important;
    box-shadow: 0 2px 5px rgba(0,0,0,0.5) !important;
}

/* Иконка внутри */
button.chat-admin-delete i {
    color: #ffffff !important;
    font-size: 10px !important;
    line-height: 1 !important;
    display: inline-block !important;
}

/* Эффект нажатия */
button.chat-admin-delete:active {
    transform: scale(0.9) !important;
}