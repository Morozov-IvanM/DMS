<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMR — Лента проектов</title>
    <!-- Библиотеки и стили (порядок верный) -->
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='fontawesome/css/all.min.css') }}"> 
    <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/components.css') }}">  
    <link rel="stylesheet" href="{{ url_for('static', path='css/projects.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/chat.css') }}">
</head>
<body>		
    <!-- Хедер (убираем лишний тег header, так как он внутри include) -->
    {% include 'partials/header.html' %}    

    <div class="page-container">
        
        <!-- БЛОК ЧАТА И ИЗБРАННОГО (теперь в две колонки) -->
        <div class="chat-layout-wrapper">
            <div class="chat-main-section">
                {% include 'partials/chat.html' %}
            </div>           
            <div class="chat-favorites-section">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3 border-bottom">
                        <span class="fw-bold small text-uppercase text-muted">
                            <i class="fas fa-star text-warning me-2"></i> Избранные проекты
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div class="favorites-list" id="favorites-container">
                            <!-- Сюда позже выведем список избранных -->
                            <div class="text-center py-5 text-muted small">
                                <i class="fas fa-folder-plus opacity-25 mb-2 fa-2x"></i>
                                <p>Здесь будет список<br>ваших важных проектов</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Форма создания проекта -->
        {% include 'partials/create_project_form.html' %}

        <!-- Основной контент: Лента проектов и Комментарии -->
        <div class="two-columns">
            <div class="left-column">
                {% include 'partials/projects_list.html' %}
            </div>
            <div class="right-column">
                {% include 'partials/recent_comments.html' %}
            </div>
        </div>

        {% include 'partials/footer.html' %}
    </div>
	
    {% include 'partials/scripts.html' %}
    
    <!-- Твои скрипты редактирования чата -->
    <script>
        function toggleChatEdit(msgId) {
            const textDiv = document.getElementById(`chat-text-${msgId}`);
            const editBlock = document.getElementById(`chat-edit-block-${msgId}`);
            if (editBlock.style.display === 'none') {
                editBlock.style.display = 'block';
                textDiv.style.display = 'none';
                const input = document.getElementById(`edit-input-${msgId}`);
                input.focus();
            } else {
                editBlock.style.display = 'none';
                textDiv.style.display = 'block';
            }
        }
        // ... (остальные функции без изменений)
    </script>
<script>
    window.toggleFavorite = function(projectId, btn) {
		fetch(`/api/projects/${projectId}/favorite`, { method: 'POST' })
		.then(res => res.json())
		.then(data => {
			if (data.success) {
				const icon = btn.querySelector('i');
				const favContainer = document.getElementById('favorites-container');
				
				if (data.status === 'added') {
					// 1. Красим звезду
					btn.classList.add('active');
					icon.classList.replace('far', 'fas');
					
					// 2. Добавляем в список справа (создаем элемент на лету)
					// Находим название проекта в текущей карточке
					const projectName = btn.closest('.position-relative').querySelector('.project-grid-title').innerText;
					
					const newItem = document.createElement('a');
					newItem.href = `/project/${projectId}`;
					newItem.className = 'fav-item-link';
					newItem.id = `fav-side-${projectId}`;
					newItem.innerHTML = `
						<i class="fas fa-folder text-primary me-2"></i>
						<span class="text-truncate">${projectName}</span>
						<i class="fas fa-chevron-right ms-auto small opacity-50"></i>
					`;
					
					// Если была заглушка "Здесь пока пусто", удаляем её
					if (favContainer.querySelector('.text-center')) {
						favContainer.innerHTML = '';
					}
					favContainer.appendChild(newItem);
					
				} else {
					// 1. Гасим звезду
					btn.classList.remove('active');
					icon.classList.replace('fas', 'far');
					
					// 2. Удаляем из списка справа
					const itemToRemove = document.getElementById(`fav-side-${projectId}`);
					if (itemToRemove) itemToRemove.remove();
					
					// Если список стал пустым, возвращаем заглушку
					if (favContainer.children.length === 0) {
						favContainer.innerHTML = `
							<div class="text-center py-5 text-muted small">
								<i class="fas fa-star-half-alt opacity-25 mb-2 fa-2x"></i>
								<p>Нажмите ⭐ на карточке,<br>чтобы закрепить проект</p>
							</div>`;
					}
				}
			}
		});
	};
</script>
</body>
</html>