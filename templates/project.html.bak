<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ project[1] if project else 'Проект' }} | CMR</title>
    
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='fontawesome/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/components.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/project-details.css') }}">
</head>
<body>
    {% include 'partials/header.html' %}

    <main class="page-container">
        {% if project %}
            <!-- Панель управления проектом -->
            <div class="d-flex justify-content-between align-items-center mb-4">               
                {% if project[3] == 'Active' %}
                    <!-- Красная кнопка архивации -->
                    <form action="/archive-project/{{ project[0] }}/" method="post" onsubmit="return confirm('Завершить проект и отправить в архив?');">
                        <button type="submit" class="btn-finish-project">
                            <div class="btn-content">
                                <i class="fas fa-check-double"></i>
                                <span>Завершить и архивировать</span>
                            </div>
                            <div class="btn-shine"></div>
                        </button>
                    </form>
                {% else %}
                    <!-- Зеленая кнопка восстановления -->
                    <form action="/project/{{ project[0] }}/restore" method="post" onsubmit="return confirm('Вернуть проект в работу?');">
                        <button type="submit" class="btn-restore-project">
                            <div class="btn-content">
                                <i class="fas fa-undo-alt"></i>
                                <span>Вернуть в работу</span>
                            </div>
                            <div class="btn-shine"></div>
                        </button>
                    </form>
                {% endif %}
            </div>

            <!-- Карточка проекта -->
            <div class="project-detail-card shadow-sm">
                <div class="project-header">
                    <div class="project-icon"><i class="fas fa-folder-open"></i></div>
                    <div class="project-info">
                        <h1 class="project-title">{{ project[1] }}</h1>
                        <div class="project-meta">
                            <span class="badge {% if project[3] == 'Active' %}bg-success{% else %}bg-secondary{% endif %}">
                                <i class="fas {% if project[3] == 'Active' %}fa-play-circle{% else %}fa-archive{% endif %} me-1"></i>
                                {{ 'Активен' if project[3] == 'Active' else 'В архиве' }}
                            </span>
                            <span class="project-id ms-2 text-muted">ID: {{ project[0] }}</span>
                        </div>
                    </div>
                </div>
                <div class="project-description mt-3">
                    <p class="mb-0 text-white">{{ project[2] if project[2] else 'Описание отсутствует' }}</p>
                </div>
            </div>

            <!-- ФОРМА ДОБАВЛЕНИЯ ЗАПИСИ (Стиль чата) -->
            {% if project[3] == 'Active' %}
            <div class="project-comment-input-area mb-5">
                <form action="/project/{{ project[0] }}/comment" method="post" enctype="multipart/form-data">
                    <div class="chat-input-wrapper shadow-sm">
                        <label class="chat-attach-btn" for="comment-file" title="Приложить документ">
                            <i class="fas fa-paperclip"></i>
                            <input type="file" name="file" id="comment-file" style="display:none" onchange="showProjectFilePreview(this)">
                        </label>
                        <textarea name="text" id="project-comment-input" class="chat-input-field" 
							placeholder="Написать комментарий в проект..." required 
							rows="1" oninput="autoResize(this)"></textarea>
                        <button class="chat-send-btn" type="submit">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                    <div id="project-file-preview" class="file-preview-bar shadow-sm" style="display:none; margin-top: 10px; background: #3b82f6; color: white; padding: 5px 15px; border-radius: 10px;">
                        <div class="d-flex align-items-center justify-content-between w-100">
                            <span id="project-file-name" class="small text-truncate me-2"></span>
                            <i class="fas fa-times-circle" onclick="clearProjectFile()" style="cursor:pointer;"></i>
                        </div>
                    </div>
                </form>
            </div>
            {% endif %}
				
            <!-- Секция обсуждения -->
            <div class="comments-section-wrapper">
                <h5 class="fw-bold mb-3 text-white-50">
                    <i class="fas fa-comments me-2"></i>Обсуждение ({{ comments|length }})
                </h5>
                <div class="comments-feed">
                    {% for c in comments %}
					<div class="comment-card shadow-sm">
						<div class="comment-header d-flex justify-content-between align-items-center">
							<div>
								<i class="fas fa-user-circle me-1 text-primary"></i>
								<span class="comment-author">{{ c[1] }}</span>
							</div>
							
							<div class="d-flex align-items-center">
								
								
								<!-- КНОПКА Редактирования только автором) -->
								{% if c[1]|lower == user_name|lower %}
								<button type="button" class="btn btn-link text-info p-0 me-3 border-0" 
										onclick="toggleEditForm('{{ c[0] }}')" title="Изменить">
									<i class="fas fa-pen" style="font-size: 0.8rem;"></i>
								</button>
								{% endif %}

								<!-- КНОПКА УДАЛЕНИЯ (для админа) -->
								{% if user_name == "Администратор" %}
								<button type="button" class="btn btn-link text-danger p-0 me-3 border-0" 
										onclick="confirmDeleteProjectComment('{{ c[0] }}', this)" title="Удалить">
									<i class="fas fa-trash-alt" style="font-size: 0.8rem;"></i>
								</button>
								{% endif %}
								
								<small class="text-muted">{{ c[3].strftime('%d.%m.%Y %H:%M') if c[3] else '' }}</small>
							</div>
						</div>

						<div class="comment-body">
							<!-- Обычный текст -->
							<pre class="comment-text-multi" id="display-text-{{ c[0] }}">{{ c[2] }}</pre>

							<!-- СКРЫТАЯ ФОРМА РЕДАКТИРОВАНИЯ -->
							<div id="edit-block-{{ c[0] }}" style="display: none;" class="mt-2">
								<form action="/comment/{{ c[0] }}/edit" method="post">
									<input type="hidden" name="p_id" value="{{ project[0] }}">
									<textarea name="text" class="custom-textarea w-100" rows="3" oninput="autoResize(this)">{{ c[2] }}</textarea>
									<div class="d-flex gap-2 mt-2">
										<button type="submit" class="btn btn-primary btn-sm px-3">Сохранить</button>
										<button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleEditForm('{{ c[0] }}')">Отмена</button>
									</div>
								</form>
							</div>
							
							<!-- ВЛОЖЕНИЯ (без изменений) -->
							...
						</div>
					</div>
                    
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </main>

    {% include 'partials/footer.html' %}

    <script src="{{ url_for('static', path='js/bootstrap.bundle.min.js') }}"></script>
    
    <script>
        // 1. Предпросмотр файла
        function showProjectFilePreview(input) {
            const preview = document.getElementById('project-file-preview');
            const nameSpan = document.getElementById('project-file-name');
            if (input.files && input.files[0]) {
                nameSpan.innerText = "📎 " + input.files[0].name;
                preview.style.display = 'flex';
            }
        }

        function clearProjectFile() {
            const input = document.getElementById('comment-file');
            const preview = document.getElementById('project-file-preview');
            input.value = "";
            preview.style.display = 'none';
        }

        // 2. Авто-высота текстового поля
        function autoResize(textarea) {
            textarea.style.height = 'auto'; 
            const newHeight = Math.min(textarea.scrollHeight, 200); 
            textarea.style.height = newHeight + 'px';
        }

        // 3. Отправка по Enter (Shift+Enter для новой строки)
        document.addEventListener('DOMContentLoaded', function() {
            const input = document.getElementById('project-comment-input');
            if (input) {
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault(); 
                        if (this.value.trim() !== "" || document.getElementById('comment-file').files.length > 0) {
                            this.form.submit();
                        }
                    }
                });
            }
        });
		function toggleEditForm(commentId) {
			const textDisplay = document.getElementById(`display-text-${commentId}`);
			const editBlock = document.getElementById(`edit-block-${commentId}`);
			
			if (editBlock.style.display === 'none') {
				editBlock.style.display = 'block';
				textDisplay.style.display = 'none';
				// Находим textarea внутри и подгоняем высоту
				const area = editBlock.querySelector('textarea');
				autoResize(area); 
				area.focus();
			} else {
				editBlock.style.display = 'none';
				textDisplay.style.display = 'block';
			}
		}	
    </script>
</body>
</html>