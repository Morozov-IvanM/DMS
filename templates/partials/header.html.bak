<head>
    <meta charset="UTF-8">
    <title>CMR — Лента проектов</title>
    
    <!-- 1. Базовые стили библиотеки -->
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    
    <!-- 2. Изолированные стили чата -->
    <link rel="stylesheet" href="{{ url_for('static', path='css/chat.css') }}">
    
    <!-- 3. гигантский файл CSS -->
    <link rel="stylesheet" href="{{ url_for('static', path='css/corporate_reddit.css') }}">
</head>
<div class="header-content">
	<div class="logo">
		<i class="fas fa-code-branch"></i> CM<a href="EasterEgg.html" class="easter-link">R</a> Safe Region 34
	</div>
	
	<div class="header-actions">
		<!-- 1. Динамическая кнопка: Архив или Назад -->
		{% if request.url.path == "/archive" %}
			<a href="/" class="btn-archive-link text-decoration-none">
				<i class="fas fa-arrow-left"></i> Назад
			</a>
		{% else %}
			<a href="/archive" class="btn-archive-link text-decoration-none">
				<i class="fas fa-archive"></i> Архив
			</a>
		{% endif %}

		<!-- 2. Динамический поиск: ищет там, где мы сейчас находимся -->
		<form action="{{ request.url.path }}" method="get" class="search-form">
			<div class="search-wrapper">
				<i class="fas fa-search search-icon"></i>
				<input type="text" name="q" class="search-input" 
					   placeholder="{% if request.url.path == '/archive' %}Поиск в архиве...{% else %}Поиск проектов...{% endif %}" 
					   value="{{ search_query or '' }}">
				<button type="submit" class="search-btn">Найти</button>
			</div>
		</form>

		<!-- 3. Информация о пользователе -->
		<div class="user-info">
			<div class="user-badge">
				<i class="fas fa-user-circle"></i> <strong>{{ user_name }}</strong>
			</div>
			<div class="form-check form-switch ms-3">
				<input class="form-check-input" type="checkbox" id="notifySwitch" 
					   onclick="toggleNotifications(this.checked)" checked>
				<label class="form-check-label small text-muted" for="notifySwitch">Уведомления</label>
			</div>
			

			<a href="/logout" class="btn-logout" title="Выйти">
				<i class="fas fa-sign-out-alt"></i> Выйти
			</a>
		</div>
	</div>
</div>


<script>
	// Устанавливаем положение свитча из памяти при загрузке
	document.getElementById('notifySwitch').checked = localStorage.getItem('notifications_enabled') !== 'false';
</script>	
