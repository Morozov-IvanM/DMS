<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Авторизация | CMR Safe Region 34</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/static/corporate_reddit.css">
    <style>
        .tabs { display: flex; gap: 10px; margin-bottom: 20px; border-bottom: 1px solid #ddd; }
        .tab-btn { border: none; background: none; padding: 10px; cursor: pointer; color: #666; }
        .tab-btn.active { color: #0d6efd; border-bottom: 2px solid #0d6efd; font-weight: bold; }
        .form-section { display: none; }
        .form-section.active { display: block; }
        .error-msg { color: #dc3545; font-size: 0.85rem; margin-bottom: 15px; text-align: center; }
    </style>
</head>
<body class="login-page">
    <div class="login-container">
        <div class="card shadow-lg">
            <div class="card-icon">
                <i class="fas fa-lock-shield"></i>
            </div>
            
            <h2>CMR Safe Region 34</h2>
            <div class="subtitle">Проекты, файлы и чат</div>

            {% if error %}
                <div class="error-msg"><i class="fas fa-exclamation-circle"></i> {{ error }}</div>
            {% endif %}

            <!-- Переключатель Вход / Регистрация -->
            <div class="tabs">
                <button class="tab-btn active" onclick="showTab('login-form', this)">Вход</button>
                <button class="tab-btn" onclick="showTab('register-form', this)">Регистрация</button>
            </div>
            
            <!-- ФОРМА ВХОДА -->
            <form action="/login" method="post" id="login-form" class="form-section active">
                <div class="form-group">
                    <label>Логин или Email</label>
                    <div class="input-wrapper">
                        <i class="fas fa-at input-icon"></i>
                        <input type="text" name="login_field" placeholder="ivanov@cmr.ru" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Пароль</label>
                    <div class="input-wrapper">
                        <i class="fas fa-key input-icon"></i>
                        <input type="password" name="password" placeholder="••••••••" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-sign-in-alt"></i> Войти
                </button>
            </form>

            <!-- ФОРМА РЕГИСТРАЦИИ -->
            <form action="/register" method="post" id="register-form" class="form-section">
                <div class="form-group">
                    <label>Ваше ФИО / Никнейм</label>
                    <div class="input-wrapper">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" name="username" placeholder="Иванов Иван" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Корпоративная почта</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" placeholder="user@corp.ru" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Пароль</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" placeholder="Придумайте пароль" required>
                    </div>
                </div>
                <button type="submit" class="btn btn-success w-100">
                    <i class="fas fa-user-plus"></i> Создать аккаунт
                </button>
            </form>
            
            <div class="divider">
                <span>Внутренняя сеть</span>
            </div>
            
            <div class="card-footer" style="flex-direction: column; gap: 5px;">
                <div>
                    <i class="fas fa-shield-alt"></i>
                    <span>&copy; 2026 Морозов & Бабенко & Волков (DOK).	Безопасный регион.</span>
                </div>
                <div style="font-size: 0.8rem; opacity: 0.8;">
                    <i class="fas fa-phone-alt"></i>
                    <span>По вопросам работоспособности 96-62-20</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showTab(formId, btn) {
            document.querySelectorAll('.form-section').forEach(f => f.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(formId).classList.add('active');
            btn.classList.add('active');
        }
		window.onload = function() {
			const urlParams = new URLSearchParams(window.location.search);
			if (urlParams.has('success')) {
				// Принудительно показываем форму входа, если регистрация прошла успешно
				showTab('login-form', document.querySelector('.tab-btn:first-child'));
			}
		}
    </script>
</body>
</html>