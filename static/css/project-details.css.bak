/* ============================================
   ДОПОЛНИТЕЛЬНЫЕ СТИЛИ ДЛЯ СТРАНИЦЫ ПРОЕКТА
   ============================================ */

/* Хедер действия */
.header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.inline-form {
    display: inline;
}

.btn-archive, .btn-restore {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
    padding: 0.5rem 1rem;
    border-radius: 40px;
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
    font-family: inherit;
}

.btn-archive:hover {
    background: var(--danger);
    color: white;
}

.btn-restore {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.btn-restore:hover {
    background: var(--success);
    color: white;
}

/* Счётчик в мета-информации */
.comments-count-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--bg-input);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-secondary);
}

/* Кастомная textarea */
.custom-textarea {
    width: 100%;
    min-height: 120px;
    padding: 1rem;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 16px;
    font-size: 0.95rem;
    color: var(--text-main);
    font-family: inherit;
    resize: vertical;
    transition: all 0.2s;
}

.custom-textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
}

.custom-textarea::placeholder {
    color: var(--text-secondary);
}

/* Уведомление об архивации */
.archived-notice {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
}

.archived-notice i {
    font-size: 3rem;
    color: var(--text-secondary);
    opacity: 0.5;
}

.archived-notice-content h4 {
    margin-bottom: 0.5rem;
    color: var(--text-main);
}

.archived-notice-content p {
    color: var(--text-secondary);
    margin: 0;
}

/* Адаптив для хедера */
@media (max-width: 640px) {
    .header-content {
        flex-direction: column;
        text-align: center;
    }
    
    .header-actions {
        flex-wrap: wrap;
        justify-content: center;
    }
    
    .project-meta {
        gap: 0.5rem;
    }
    
    .comments-count-badge {
        font-size: 0.65rem;
    }
}
