<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Архив проектов | CMR</title>
    <link rel="stylesheet" href="{{ url_for('static', path='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='fontawesome/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/base.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/layout.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/components.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', path='css/projects.css') }}">
</head>
<body class="bg-page"> <!-- Используем переменную фона из base.css -->
    
    {% include 'partials/header.html' %}

    <main class="page-container">
        <!-- Герой-секция архива в темном стиле -->
        <div class="archive-hero shadow-sm rounded-4 p-4 mb-4 text-white" style="background: linear-gradient(135deg, #1a1d26 0%, #242834 100%); border: 1px solid #303645;">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="archive-hero-icon me-4 text-secondary" style="font-size: 3rem;">
                        <i class="fas fa-archive"></i>
                    </div>
                    <div>
                        <h1 class="h3 mb-1 fw-bold">Архив проектов</h1>
                        <p class="mb-0 text-white-50">История завершённых задач вашей группы.</p>
                    </div>
                </div>
                <div class="archive-stats text-center border-start border-secondary ps-4">
                    <div class="stat-value h3 mb-0 fw-bold text-warning">{{ projects|length }}</div>
                    <div class="stat-label small text-uppercase text-white-50">Завершено</div>
                </div>
            </div>
        </div>

		<!-- Контейнер архива в две колонки -->
		<div class="archive-grid-container">
			{% if projects %}
				{% for p in projects %}
				<a href="/project/{{ p[0] }}" class="project-link">
					<div class="project-grid-card h-100"> <!-- h-100 чтобы карточки в ряду были одной высоты -->
						<div class="project-card-header">
							<span class="project-id-badge">#{{ p[0] }}</span>
							<span class="badge bg-secondary border border-secondary-subtle">
								<i class="fas fa-history me-1"></i>Архив
							</span>
						</div>
						
						<h4 class="project-card-title">{{ p[1] }}</h4>
						
						<p class="project-card-description">
							{{ p[2][:100] + '...' if p[2] and p[2]|length > 100 else p[2] or 'Описание отсутствует' }}
						</p>
						
						<div class="project-card-footer mt-auto"> <!-- mt-auto прижмет футер вниз -->
							<span class="card-action text-muted">
								<i class="fas fa-eye me-1"></i> Детали
							</span>
							<span class="ms-auto small text-muted">
								<i class="fas fa-calendar-check me-1"></i> {{ p[3] }}
							</span>
						</div>
					</div>
				</a>
				{% endfor %}
			{% else %}
				<!-- Заглушка (на всю ширину) -->
				<div class="empty-state-card w-100" style="grid-column: 1 / -1;">
					<i class="fas fa-box-open mb-3 opacity-25" style="font-size: 4rem;"></i>
					<h3 class="text-white-50">Архив пока пуст</h3>
				</div>
			{% endif %}
		</div>
		
		
    </main>

    {% include 'partials/footer.html' %}
    {% include 'partials/scripts.html' %}
</body>
</html>