/* ==========================================================
   ADMIN PANEL: LIGHT PROFESSIONAL STYLE
   ========================================================== */

/* Фон всей страницы админки (переопределяем для легкости) */
body.admin-body {
    background-color: #f4f7f9 !important;
    color: #334155 !important;
}

/* Карточки управления */
.admin-card {
    background: #ffffff;
    border: none;
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    margin-bottom: 1.5rem;
}

.admin-card-header {
    background-color: #ffffff;
    border-bottom: 1px solid #e2e8f0;
    padding: 1.25rem;
    font-weight: 700;
    font-size: 1.1rem;
    border-radius: 12px 12px 0 0;
}

/* Таблица пользователей */
.admin-table-container {
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
}

.table.admin-table {
    margin-bottom: 0;
}

.admin-table thead {
    background-color: #f8fafc;
}

.admin-table th {
    color: #64748b;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.025em;
    padding: 1rem;
    border-bottom: 1px solid #e2e8f0;
}

.admin-table td {
    padding: 1rem;
    vertical-align: middle;
    border-bottom: 1px solid #f1f5f9;
    color: #1e293b;
}

.admin-table tbody tr:hover {
    background-color: #f1f5f9;
}

/* Боковое меню */
.admin-sidebar .list-group-item {
    border: none;
    margin-bottom: 0.25rem;
    border-radius: 8px !important;
    color: #475569;
    font-weight: 500;
    padding: 0.75rem 1rem;
    background: transparent;
}

.admin-sidebar .list-group-item:hover {
    background-color: #e2e8f0;
    color: #0f172a;
}

.admin-sidebar .list-group-item.active {
    background-color: #3b82f6 !important;
    color: #ffffff !important;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
}

/* Формы ввода */
.admin-input {
    background-color: #ffffff !important;
    border: 1px solid #cbd5e1 !important;
    color: #0f172a !important;
    border-radius: 8px !important;
}

.admin-input:focus {
    border-color: #3b82f6 !important;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
}

/* Кнопки */
.btn-admin-action {
    border-radius: 8px;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    transition: all 0.2s;
}
/* Улучшенное уведомление об успехе */
.alert-success-custom {
    background-color: #ffffff !important;
    border-left: 5px solid #28a745 !important; /* Сочная зеленая полоса слева */
    color: #155724 !important;
    padding: 1rem 1.5rem !important;
    border-radius: 10px !important;
    margin-bottom: 2rem !important;
    border: 1px solid #e2e8f0;
}

/* Контейнер для иконки */
.success-icon-wrapper {
    color: #28a745;
    background: rgba(40, 167, 69, 0.1);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Анимация появления (выезжает сверху и плавно проявляется) */
.animate-success {
    animation: slideDownFade 0.5s ease-out forwards;
}

@keyframes slideDownFade {
    0% {
        opacity: 0;
        transform: translateY(-20px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Текст заголовка в уведомлении */
.alert-success-custom strong {
    font-size: 0.95rem;
    color: #1e293b;
}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const alert = document.getElementById('success-alert');
    
    if (alert) {
        // 1. Убираем параметр из URL сразу, чтобы при F5 плашка не вылезла снова
        const url = new URL(window.location);
        url.searchParams.delete('success');
        window.history.replaceState({}, document.title, url);

        // 2. Автоматически скрываем плашку через 5 секунд
        setTimeout(() => {
            alert.style.transition = "opacity 0.5s ease, transform 0.5s ease";
            alert.style.opacity = "0";
            alert.style.transform = "translateY(-20px)";
            
            // Удаляем элемент из кода после анимации
            setTimeout(() => alert.remove(), 500);
        }, 5000);
    }
});
</script>