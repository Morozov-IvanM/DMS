<div class="right-column">
	<div class="card recent-comments-card border-0 shadow-sm">
		<div class="card-header bg-white py-3">
			<span class="fw-bold small text-uppercase text-muted">
				<i class="fas fa-history me-2 text-info"></i> Последние комментарии
			</span>
		</div>
		<div class="comments-list-sidebar">
			{% if last_comments %}
				{% for comm in last_comments %}
				<a href="/project/{{ comm[3] }}" class="recent-comment-item">
					<div class="comment-header-sidebar d-flex justify-content-between align-items-start">
						<span class="comment-project-tag">{{ comm[2] }}</span>
						<!-- Время комментария -->
						<span class="comment-time-sidebar text-muted" style="font-size: 0.7rem;">
							<i class="far fa-clock me-1"></i>{{ comm[4] }}
						</span>
					</div>
					<div class="comment-author-sidebar mt-1">
						<strong>{{ comm[1] }}:</strong>
					</div>
					<p class="comment-preview-text mb-0 mt-1 text-truncate">
						{{ comm[0] }}
					</p>
				</a>
				{% endfor %}
			{% else %}
				<div class="empty-recent text-center py-4">
					<p class="text-muted small">Тишина...</p>
				</div>
			{% endif %}
		</div>
	</div>
</div>